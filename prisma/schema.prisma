generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tender {
  id              String   @id @default(uuid())
  localId         Int      @default(autoincrement())

  district        String

  title           String
  description     String?

  startDate       DateTime?
  endDate         DateTime?

  noticePdfUrl    String?
  tenderPdfUrl    String?

  tenderValue     String?
  emd             String?
  applicationCost String?

  aiSummary       String?
  tags            String[] @default([])

  aiProcessed     Boolean  @default(false)
  aiError         String?

  isBookmarked    Boolean  @default(false)
  isApplied       Boolean  @default(false)

  sourceUrl       String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([district])
  @@index([endDate])

  // Workaround for SQLite: We cannot have nullable columns in a unique constraint in SQLite cleanly
  // But wait, actually Prisma supports nullable unique constraints on SQLite starting Prisma 5
  @@unique([district, tenderPdfUrl])
}

model StateTender {
  id              String   @id @default(uuid())
  localId         Int      @default(autoincrement())

  organisation    String

  title           String
  description     String?

  startDate       DateTime?
  endDate         DateTime?

  noticePdfUrl    String?
  tenderPdfUrl    String?

  tenderValue     String?
  emd             String?
  applicationCost String?

  aiSummary       String?
  tags            String[] @default([])

  aiProcessed     Boolean  @default(false)
  aiError         String?

  isBookmarked    Boolean  @default(false)
  isApplied       Boolean  @default(false)

  sourceUrl       String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organisation])
  @@index([endDate])

  @@unique([organisation, title])
}

model ScrapeLog {
  id            String   @id @default(uuid())

  district      String

  status        String

  tendersFound  Int

  error         String?

  source        String   @default("AUTO")

  createdAt     DateTime @default(now())
}

model PriorityKeyword {
  id        String   @id @default(uuid())
  word      String   @unique
  createdAt DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model EmailRecipient {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}
